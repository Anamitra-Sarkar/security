# Example environment variables for the Sentinel system.
# Copy to .env and fill in actual values.

# Database (Render-managed Postgres)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sentinel

# Redis (Upstash or RedisCloud)
REDIS_URL=redis://localhost:6379/0

# Hugging Face API
HF_API_KEY=hf_your_token_here

# Groq API
GROQ_API_KEY=gsk_your_token_here

# JWT Authentication
JWT_SECRET=change-me-to-a-random-string

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Sentry (optional)
SENTRY_DSN=

# Qdrant Vector DB (optional)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Frontend env (set in Vercel)
# NEXT_PUBLIC_API_URL=https://sentinel-api.onrender.com
