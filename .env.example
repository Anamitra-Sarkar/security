# Sentinel – example environment variables.
# Copy to .env and fill in real values.

# ── Firebase ──────────────────────────────────────────────────────────────────
# Your Firebase project ID (found in Project Settings → General)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Set to false to skip Firestore init at startup when credentials are absent.
# This prevents google.auth RefreshError "Invalid JWT Signature" on startup.
FIRESTORE_AUTO_INIT=false

# Service account credentials.
# Option A (local dev): point to the downloaded JSON file
#   export GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json
#
# Option B (Render / CI): paste the entire JSON file as a single-line string
#   FIREBASE_CREDENTIALS_JSON='{"type":"service_account", ...}'
FIREBASE_CREDENTIALS_JSON=

# ── Redis (Upstash or local) ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Hugging Face API ──────────────────────────────────────────────────────────
HF_API_KEY=hf_your_token_here

# ── Groq API ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_token_here

# ── CORS (comma-separated allowed origins) ────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Sentry (optional) ─────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Qdrant Vector DB (optional) ───────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Frontend (set in Vercel dashboard, not here) ──────────────────────────────
# NEXT_PUBLIC_API_URL=https://sentinel-api.onrender.com
# NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
# NEXT_PUBLIC_FIREBASE_APP_ID=1:123456:web:abc
